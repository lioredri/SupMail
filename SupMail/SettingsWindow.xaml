<Window x:Class="SupMail.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Settings" Height="420" Width="400"
        WindowStartupLocation="CenterOwner" Background="#F9F9F9" ResizeMode="NoResize">
	<Grid Margin="25">
		<StackPanel>
			<TextBlock Text="Priority ERP Configuration" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" Foreground="#1A1A1A"/>

			<TextBlock Text="API Base URL" Foreground="#666666" Margin="0,0,0,5"/>
			<TextBox Name="txtApiUrl" Height="32" Padding="5,0" VerticalContentAlignment="Center" Margin="0,0,0,15"/>
			<Grid Margin="0,0,0,20">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>
				<StackPanel Grid.Column="0" Margin="0,0,10,0">
					<TextBlock Text="Username" Foreground="#666666" Margin="0,0,0,5"/>
					<TextBox Name="txtUser" Height="32" VerticalContentAlignment="Center"/>
				</StackPanel>
				<StackPanel Grid.Column="1">
					<TextBlock Text="Password" Foreground="#666666" Margin="0,0,0,5"/>
					<PasswordBox Name="txtPass" Height="32" VerticalContentAlignment="Center"/>
				</StackPanel>
			</Grid>

			<Button Name="btnTest" Content="Test Connection" Click="btnTest_Click"
                    Height="35" Background="Transparent" BorderBrush="#0078D4" Foreground="#0078D4" Margin="0,0,0,10">
				<Button.Resources>
					<Style TargetType="Border">
						<Setter Property="CornerRadius" Value="4"/>
					</Style>
				</Button.Resources>
			</Button>

			<Button Content="Save &amp; Close" Click="Save_Click" FontWeight="Bold"
                    Height="40" Background="#0078D4" Foreground="White" BorderThickness="0">
				<Button.Resources>
					<Style TargetType="Border">
						<Setter Property="CornerRadius" Value="4"/>
					</Style>
				</Button.Resources>
			</Button>
		</StackPanel>
	</Grid>
</Window>