<Window x:Class="SupMail.FileSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Select Attachments" Height="400" Width="450"
        WindowStartupLocation="CenterOwner" Background="#F9F9F9" ResizeMode="NoResize">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select files to attach" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#1A1A1A"/>

        <CheckBox Grid.Row="1" Name="chkSelectAll" Content="Select All" FontWeight="SemiBold" Margin="0,0,0,10"
                  IsChecked="True" Checked="ChkSelectAll_Changed" Unchecked="ChkSelectAll_Changed"/>

        <ListView Grid.Row="2" x:Name="lstFiles" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15"
          ScrollViewer.VerticalScrollBarVisibility="Auto" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListView.View>
                <GridView>
                    <!-- Column 1: Checkbox and File Name -->
                    <GridViewColumn Header="File Name" Width="250">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}" Margin="5,4"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column 2: File Size -->
                    <GridViewColumn Header="Size" Width="100" DisplayMemberBinding="{Binding FileSize}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Cancel" Height="35" Margin="0,0,5,0"
                    Background="Transparent" BorderBrush="#0078D4" Foreground="#0078D4"
                    Click="Cancel_Click">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Grid.Column="1" x:Name="btnZip" Content="Zip Selected" Height="35" Margin="5,0,5,0"
                    Background="Transparent" BorderBrush="#107C10" Foreground="#107C10"
                    Click="ZipSelected_Click">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Grid.Column="2" Content="Attach Selected" Height="35" Margin="5,0,0,0"
                    Background="#0078D4" Foreground="White" BorderThickness="0" FontWeight="Bold"
                    Click="Confirm_Click">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>
